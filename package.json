{
  "name": "ms-agent-js",
  "description": "The modern, dependency-free Clippy for the web. A TypeScript-based Microsoft Agent implementation perfect for nostalgic apps and unique AI/LLM interfaces.",
  "private": false,
  "version": "0.4.1",
  "type": "module",
  "author": "Microsoft Agent JS Contributors",
  "license": "MIT",
  "keywords": [
    "msagent",
    "clippy",
    "clippy-js",
    "microsoft-agent",
    "nostalgia",
    "windows-98",
    "office-2000",
    "typescript",
    "web-assistant",
    "ai-ui",
    "llm-assistant",
    "interactive-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azayrahmad/ms-agent-js.git"
  },
  "bugs": {
    "url": "https://github.com/azayrahmad/ms-agent-js/issues"
  },
  "homepage": "https://azayrahmad.github.io/ms-agent-js/",
  "main": "./dist/ms-agent-js.umd.js",
  "module": "./dist/ms-agent-js.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ms-agent-js.es.js",
      "require": "./dist/ms-agent-js.umd.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:app",
    "build:lib": "tsc && vite build",
    "build:app": "tsc && vite build --mode app",
    "preview": "npm run build:app && vite preview --mode app",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "canvas": "^3.2.2",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  }
}
